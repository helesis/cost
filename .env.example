# Cost Analysis API — örnek ortam değişkenleri
# Kopyalayın: cp .env.example .env  ardından değerleri düzenleyin.

# ── Sunucu ─────────────────────────────────────────────────────────────────────
PORT=3010
# production | development | boş (geliştirme varsayılanı)
NODE_ENV=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=voyagestars
DB_USER=postgres
DB_PASSWORD=postgres

# ── Ollama (ürün sınıflandırma) ───────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=gemma2:27b
